CLICKHOUSE_VERSION=26.6.1.1193-alpine
CLICKHOUSE_DB=analytics
CLICKHOUSE_USER=analytics
CLICKHOUSE_PASSWORD=analytics_password

LOGS_FILE=/Users/subbotaevgenij/ES_raw_logs_json
LOGS_INPUT_FORMAT=auto
LOGS_SOURCE_NAME=elasticsearch-synthetic
LOGS_INDEX_NAME=synthetic-logs
LOGS_BATCH_SIZE=10000
LOGS_PROGRESS_EVERY=100000
LOGS_INDEX_LIKE=synthetic-logs%
LOG_COMPRESS_BATCH_ROWS=5000
LOG_COMPRESS_PROGRESS_EVERY=100

INVESTIGATION_ID=
USER_QUESTION=
TIME_FROM=
TIME_TO=
MAP_WORKER_ID=
MAP_WORKER_INDEX=0
MAP_WORKER_COUNT=1
MAP_CLAIM_SIZE=10
MAP_LEASE_SECONDS=900
MAP_MAX_ATTEMPTS=3
MAP_MAX_ITERATIONS=1

LLM_API_KEY=replace-with-api-key
LLM_BASE_URL=https://api.openai.com/v1
LLM_CHAT_COMPLETIONS_ENDPOINT=https://api.openai.com/v1/chat/completions
LLM_MAP_API_KEY=replace-with-map-api-key
LLM_MAP_BASE_URL=https://api.openai.com/v1
LLM_MAP_CHAT_COMPLETIONS_ENDPOINT=https://api.openai.com/v1/chat/completions
LLM_REDUCE_API_KEY=replace-with-reduce-api-key
LLM_REDUCE_BASE_URL=https://api.openai.com/v1
LLM_REDUCE_CHAT_COMPLETIONS_ENDPOINT=https://api.openai.com/v1/chat/completions
LLM_MAP_MODEL=gpt-4.1-mini
LLM_REDUCE_MODEL=gpt-4.1

AI_FUNCTION_MAX_API_CALLS_PER_QUERY=64
AI_FUNCTION_MAX_INPUT_TOKENS_PER_QUERY=1000000
AI_FUNCTION_MAX_OUTPUT_TOKENS_PER_QUERY=200000
AI_FUNCTION_REQUEST_TIMEOUT_SEC=120
AI_FUNCTION_MAX_RETRIES=2

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_BASE_URL=http://localhost:3001

LIBRECHAT_DOMAIN=http://localhost:3080
LIBRECHAT_IMAGE=registry.librechat.ai/danny-avila/librechat-dev:latest
JWT_SECRET=replace-with-64-hex-chars
JWT_REFRESH_SECRET=replace-with-64-hex-chars
CREDS_KEY=replace-with-64-hex-chars
CREDS_IV=replace-with-32-hex-chars
